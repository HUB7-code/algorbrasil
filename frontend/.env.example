# ============================================================
# ALGOR BRASIL - Frontend - Variáveis de Ambiente
# ============================================================
#
# INSTRUÇÕES:
# 1. Copie este arquivo para .env.local (remova o .example)
# 2. Preencha com seus valores reais
# 3. NUNCA commite o arquivo .env.local no repositório!
#
# ============================================================

# ========================================
# API / Backend
# ========================================
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ========================================
# Clerk - Autenticação (OBRIGATÓRIO)
# ========================================
# Obtenha suas chaves em: https://dashboard.clerk.com/last-active?path=api-keys
#
# No GitHub Actions, configure os seguintes secrets em:
#   Settings > Secrets and variables > Actions
#
#   - NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY  (chave pública — começa com pk_)
#   - CLERK_SECRET_KEY                  (chave secreta  — começa com sk_)
#
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your-publishable-key-here
CLERK_SECRET_KEY=sk_test_your-secret-key-here
